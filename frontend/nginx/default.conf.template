server {
  listen 80;
  root /usr/share/nginx/html;
  index index.html;

  # VPC resolver with a short TTL so nginx re-resolves Cloud Map hostnames
  # on each request rather than caching the IP at startup.
  resolver 169.254.169.253 valid=10s ipv6=off;

  location /api/ {
    set $backend http://${BACKEND_HOST}:${BACKEND_PORT};
    proxy_pass $backend/;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
  }

  location / {
    try_files $uri /index.html;
  }
}
